{
  // Cursor IDE auto-run allowlist.
  // Doc: https://cursor.com/docs/reference/permissions
  // Active uniquement si Auto-Run = "Run in Sandbox" ou "Run Everything"
  // (Cursor Settings > Agents > Auto-Run). Recommandé: Run in Sandbox.
  // Préfixes shell case-sensitive. server:tool case-insensitive avec wildcards *.

  "terminalAllowlist": [
    // --- Filesystem read-only ---
    "ls",
    "pwd",
    "cd",
    "stat",
    "file",
    "wc",
    "head",
    "tail",
    "cat",
    "tree",
    "du",
    "df",
    "which",
    "type",
    "whoami",
    "uname",
    "hostname",
    "date",
    "echo",
    "printf",
    "env",
    "printenv",
    "true",
    "false",
    "test",

    // --- Search / pipes ---
    "rg",
    "grep",
    "fd",
    "ag",
    "find",
    "sort",
    "uniq",
    "cut",
    "tr",
    "column",
    "tee",
    "diff",
    "cmp",
    "comm",
    "xargs",
    "awk",
    "jq",
    "yq",
    "tldr",
    "sed:-n*",

    // --- Git read-only ---
    "git status",
    "git diff",
    "git log",
    "git show",
    "git branch",
    "git tag",
    "git remote",
    "git fetch",
    "git ls-files",
    "git ls-remote",
    "git blame",
    "git rev-parse",
    "git rev-list",
    "git for-each-ref",
    "git describe",
    "git shortlog",
    "git reflog",
    "git config:--get*",
    "git config:--list*",
    "git stash list",
    "git stash show",
    "git worktree list",
    "git cat-file",
    "git fsck",
    "git count-objects",
    "git verify-pack",
    "git verify-commit",
    "git verify-tag",
    "git grep",
    "git symbolic-ref",
    "git merge-base",
    "git name-rev",
    "git check-ignore",

    // --- GitLab CLI (read) ---
    "glab mr view",
    "glab mr list",
    "glab mr diff",
    "glab mr checkout",
    "glab mr note:--list*",
    "glab issue view",
    "glab issue list",
    "glab pipeline view",
    "glab pipeline list",
    "glab pipeline status",
    "glab pipeline ci view",
    "glab pipeline ci trace",
    "glab pipeline ci status",
    "glab ci view",
    "glab ci status",
    "glab ci trace",
    "glab ci list",
    "glab ci get",
    "glab ci artifact",
    "glab job",
    "glab repo view",
    "glab api:GET*",
    "glab auth status",

    // --- GitHub CLI (read) ---
    "gh pr view",
    "gh pr list",
    "gh pr diff",
    "gh pr checks",
    "gh pr status",
    "gh issue view",
    "gh issue list",
    "gh repo view",
    "gh run view",
    "gh run list",
    "gh release view",
    "gh release list",
    "gh api:--method GET*",
    "gh auth status",

    // --- Elixir / Phoenix ---
    "mix help",
    "mix deps",
    "mix deps.get",
    "mix deps.tree",
    "mix compile",
    "mix format",
    "mix credo",
    "mix dialyzer",
    "mix lint",
    "mix lint.quick",
    "mix lint.full",
    "mix lint.ci",
    "mix test",
    "mix coveralls",
    "mix xref",
    "mix gettext.extract",
    "mix phx.routes",
    "mix ecto.migrations",
    "mix run:--no-start*",
    "elixir",
    "iex:--help*",
    "asdf current",
    "asdf list",
    "mise exec",
    "mise run",
    "mise which",
    "mise current",
    "mise ls",
    "mise env",

    // --- Node.js / pnpm ---
    "pnpm install",
    "pnpm i",
    "pnpm dlx",
    "pnpm vitest",
    "pnpm jest",
    "pnpm test",
    "pnpm:test*",
    "pnpm lint",
    "pnpm:lint*",
    "pnpm typecheck",
    "pnpm tsc",
    "pnpm build",
    "pnpm format",
    "pnpm:format*",
    "pnpm storybook",
    "pnpm exec",
    "pnpm why",
    "pnpm list",
    "pnpm outdated",
    "pnpm audit",
    "pnpm view",
    "npm run",
    "npm test",
    "npm ls",
    "npm ci",
    "npm install",
    "npm i:--save-dev*",
    "npm audit",
    "npm outdated",
    "npm view",
    "npm doctor",
    "npm config:get*",
    "npx tsc",
    "npx prettier:--check*",
    "npx eslint",
    "npx vitest",
    "npx jest",
    "node:--version",
    "node:-e*",
    "tsc:--noEmit*",

    // --- Infra: Terraform / Terragrunt (dry-run uniquement) ---
    "terraform version",
    "terraform validate",
    "terraform init:-backend=false*",
    "terraform get",
    "terraform fmt:-check*",
    "terraform fmt:-recursive -check*",
    "terraform plan",
    "terraform show",
    "terraform state list",
    "terraform state show",
    "terraform output",
    "terraform providers",
    "terragrunt --version",
    "terragrunt validate",
    "terragrunt init:-backend=false*",
    "terragrunt plan",
    "terragrunt hclfmt:--check*",
    "terragrunt run-all validate",
    "terragrunt run-all plan",
    "tflint",
    "tfsec",
    "checkov",

    // --- HTTP read-only ---
    "curl:-I*",
    "curl:--head*",
    "curl:-sSL*",
    "curl:-fsSL*",
    "wget:--spider*",

    // --- Skills / divers locaux ---
    "make help",
    "make:list*",
    "docker ps",
    "docker images",
    "docker logs",
    "docker inspect",
    "docker compose ps",
    "docker compose logs",
    "kubectl get",
    "kubectl describe",
    "kubectl logs",
    "kubectl config:current-context",
    "kubectl config:get-contexts",
    "aws sts get-caller-identity",
    "aws s3 ls",
    "aws:--version"
  ],

  "mcpAllowlist": [
    // --- Linear (lecture) ---
    "*linear*:list_*",
    "*linear*:get_*",
    "*linear*:search_*",
    "*linear*:extract_images",

    // --- GitLab (lecture / recherche) ---
    "*gitlab*:get_*",
    "*gitlab*:search",
    "*gitlab*:search_labels",
    "*gitlab*:semantic_code_search",
    "*gitlab*:get_mcp_server_version",

    // --- Notion (lecture / requêtes) ---
    "*notion*:notion-search",
    "*notion*:notion-fetch",
    "*notion*:notion-query-*",
    "*notion*:notion-get-*",

    // --- Slack (lecture / recherche) ---
    "*slack*:slack_read_*",
    "*slack*:slack_search_*",

    // --- Sentry (auth uniquement, le reste à la demande) ---
    "*sentry*:mcp_auth",

    // --- Honeycomb (entièrement lecture par nature) ---
    "Honeycomb:*",

    // --- Aikido Security (analyse read-only) ---
    "AikidoSecurityMCP:*",

    // --- Cursor IDE Browser (inspection seule) ---
    "cursor-ide-browser:browser_snapshot",
    "cursor-ide-browser:browser_take_screenshot",
    "cursor-ide-browser:browser_console_messages",
    "cursor-ide-browser:browser_network_requests",
    "cursor-ide-browser:browser_tabs",
    "cursor-ide-browser:browser_search",
    "cursor-ide-browser:browser_hover",
    "cursor-ide-browser:browser_scroll",
    "cursor-ide-browser:browser_navigate",
    "cursor-ide-browser:browser_navigate_back",
    "cursor-ide-browser:browser_lock"
  ]
}
